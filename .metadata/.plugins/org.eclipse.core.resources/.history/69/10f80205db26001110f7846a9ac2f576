server:
  port: 8080

spring:
  cloud:
    gateway:
      routes:

        # 🔐 Auth Service (No JWT required)
        - id: auth-service
          uri: http://localhost:8081
          predicates:
            - Path=/api/auth/**

        # 💊 Catalog Service (Medicines + Prescription)
        - id: catalog-service
          uri: http://localhost:8082
          predicates:
            - Path=/api/catalog/**

        # 🛒 Order Service
        - id: order-service
          uri: http://localhost:8083
          predicates:
            - Path=/api/orders/**

        # 📊 Admin Service
        - id: admin-service
          uri: http://localhost:8084
          predicates:
            - Path=/api/admin/**

      default-filters:
        - DedupeResponseHeader=Access-Control-Allow-Origin

  main:
    web-application-type: reactive