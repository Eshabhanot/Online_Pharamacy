server:
  port: 8081

spring:
  application:
    name: auth-service

  config:
    import: optional:configserver:http://localhost:8888

  cloud:
    config:
      enabled: false   # 🔥 important for Docker

jwt:
  secret: mySuperSecretKeyForJwtThatIsVerySecure1234567890

eureka:
  client:
    service-url:
      defaultZone: http://localhost:8761/eureka/

management:
  tracing:
    sampling:
      probability: 1.0

  zipkin:
    tracing:
      endpoint: http://zipkin:9411/api/v2/spans   # 🔥 FIXED for Docker

# 🔥 ADD THIS (VERY IMPORTANT)
logging:
  pattern:
    level: "%5p [${spring.application.name:},traceId=%X{traceId:-},spanId=%X{spanId:-}]"