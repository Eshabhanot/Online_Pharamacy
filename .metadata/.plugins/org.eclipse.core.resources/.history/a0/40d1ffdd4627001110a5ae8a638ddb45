package in.cg.main.client;

import org.springframework.cloud.openfeign.FeignClient;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.PathVariable;

import in.cg.main.dto.MedicineDTO;

@FeignClient(name = "catalog-service", url = "http://localhost:8081", fallback = CatalogFallback.class)
public interface CatalogClient {

    @GetMapping("/api/catalog/medicines/{id}")
    MedicineDTO getMedicineById(@PathVariable Long id);
}