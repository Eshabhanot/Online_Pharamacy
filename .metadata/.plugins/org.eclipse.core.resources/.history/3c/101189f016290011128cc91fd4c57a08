package in.cg.main.controller;

import in.cg.main.dto.MedicineRequest;
import in.cg.main.dto.MedicineResponse;
import in.cg.main.service.AdminMedicineService;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.extension.ExtendWith;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.junit.jupiter.MockitoExtension;
import org.springframework.http.HttpStatus;
import org.springframework.http.ResponseEntity;

import java.util.List;

import static org.junit.jupiter.api.Assertions.assertEquals;
import static org.junit.jupiter.api.Assertions.assertSame;
import static org.mockito.Mockito.verify;
import static org.mockito.Mockito.when;

@ExtendWith(MockitoExtension.class)
class AdminMedicineControllerTest {

    @Mock
    private AdminMedicineService adminMedicineService;

    @InjectMocks
    private AdminMedicineController adminMedicineController;

    @Test
    void getAllMedicines_returnsOk() {
        MedicineResponse medicine = new MedicineResponse();
        medicine.setId(1L);
        List<MedicineResponse> medicines = List.of(medicine);
        when(adminMedicineService.getAllMedicines()).thenReturn(medicines);

        ResponseEntity<List<MedicineResponse>> response = adminMedicineController.getAllMedicines();

        assertEquals(HttpStatus.OK, response.getStatusCode());
        assertSame(medicines, response.getBody());
        verify(adminMedicineService).getAllMedicines();
    }

    @Test
    void getMedicine_returnsOk() {
        MedicineResponse medicine = new MedicineResponse();
        medicine.setId(2L);
        when(adminMedicineService.getMedicineById(2L)).thenReturn(medicine);

        ResponseEntity<MedicineResponse> response = adminMedicineController.getMedicine(2L);

        assertEquals(HttpStatus.OK, response.getStatusCode());
        assertSame(medicine, response.getBody());
        verify(adminMedicineService).getMedicineById(2L);
    }

    @Test
    void search_returnsOk() {
        List<MedicineResponse> medicines = List.of(new MedicineResponse());
        when(adminMedicineService.searchMedicines("para")).thenReturn(medicines);

        ResponseEntity<List<MedicineResponse>> response = adminMedicineController.search("para");

        assertEquals(HttpStatus.OK, response.getStatusCode());
        assertSame(medicines, response.getBody());
        verify(adminMedicineService).searchMedicines("para");
    }

    @Test
    void addMedicine_returnsCreated() {
        MedicineRequest request = new MedicineRequest();
        MedicineResponse medicine = new MedicineResponse();
        when(adminMedicineService.addMedicine(request)).thenReturn(medicine);

        ResponseEntity<MedicineResponse> response = adminMedicineController.addMedicine(request);

        assertEquals(HttpStatus.CREATED, response.getStatusCode());
        assertSame(medicine, response.getBody());
        verify(adminMedicineService).addMedicine(request);
    }

    @Test
    void updateMedicine_returnsOk() {
        MedicineRequest request = new MedicineRequest();
        MedicineResponse medicine = new MedicineResponse();
        when(adminMedicineService.updateMedicine(7L, request)).thenReturn(medicine);

        ResponseEntity<MedicineResponse> response = adminMedicineController.updateMedicine(7L, request);

        assertEquals(HttpStatus.OK, response.getStatusCode());
        assertSame(medicine, response.getBody());
        verify(adminMedicineService).updateMedicine(7L, request);
    }

    @Test
    void deactivateMedicine_returnsSuccessMessage() {
        ResponseEntity<String> response = adminMedicineController.deactivateMedicine(9L);

        assertEquals(HttpStatus.OK, response.getStatusCode());
        assertEquals("Medicine deactivated successfully", response.getBody());
        verify(adminMedicineService).deactivateMedicine(9L);
    }
}
