server:
  port: 8081

spring:
  application:
    name: AUTH-SERVICE   # 🔥 REQUIRED for Eureka

  datasource:
    url: jdbc:mysql://localhost:3306/pharmacy_db
    username: root
    password: root
    driver-class-name: com.mysql.cj.jdbc.Driver

  jpa:
    hibernate:
      ddl-auto: update
    show-sql: true
    properties:
      hibernate:
        dialect: org.hibernate.dialect.MySQLDialect

# 🔗 Eureka Configuration
eureka:
  client:
    service-url:
      defaultZone: http://localhost:8761/eureka/