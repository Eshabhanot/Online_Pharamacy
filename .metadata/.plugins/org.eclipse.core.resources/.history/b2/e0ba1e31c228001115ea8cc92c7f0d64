server:
  port: 8081

spring:
  application:
    name: auth-service

  config:
    import: optional:configserver:http://localhost:8888

  cloud:
    config:
      enabled: false

jwt:
  secret: mySuperSecretKeyForJwtThatIsVerySecure1234567890

eureka:
  client:
    service-url:
      defaultZone: http://eureka:8761/eureka/

management:
  tracing:
    sampling:
      probability: 1.0

  zipkin:
    tracing:
      endpoint: http://zipkin:9411/api/v2/spans

# 🔥 LOGGING (IMPORTANT)
logging:
  file:
    name: /app/logs/auth-service.log   # inside container
  pattern:
    level: "%5p [${spring.application.name:},traceId=%X{traceId:-},spanId=%X{spanId:-}]"