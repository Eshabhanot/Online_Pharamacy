package in.cg.main.controller;

import java.math.BigDecimal;

import org.springframework.http.ResponseEntity;
import org.springframework.web.bind.annotation.*;

import jakarta.validation.Valid;

import in.cg.main.dto.CartItemRequest;
import in.cg.main.dto.CartResponse;
import in.cg.main.service.CartService;

@RestController
@RequestMapping("/api/orders/cart")
public class CartController {

    private final CartService cartService;

    // 🔹 Constructor Injection (No Lombok)
    public CartController(CartService cartService) {
        this.cartService = cartService;
    }

    // ✅ GET Cart
    @GetMapping
    public ResponseEntity<CartResponse> getCart(
            @RequestHeader("X-Customer-Id") Long customerId) {

        return ResponseEntity.ok(cartService.getCart(customerId));
    }

    // ✅ ADD Item
    @PostMapping("/items")
    public ResponseEntity<CartResponse> addItem(
            @RequestHeader("X-Customer-Id") Long customerId,
            @RequestBody @Valid CartItemRequest req) {

        // 🔥 Later replace with Catalog Service call
        return ResponseEntity.ok(
                cartService.addItem(
                        customerId,
                        req,
                        "Paracetamol",                 // dummy name
                        BigDecimal.valueOf(99.00),     // dummy price
                        false                          // dummy Rx flag
                )
        );
    }

    // ✅ UPDATE Item Quantity
    @PutMapping("/items/{itemId}")
    public ResponseEntity<CartResponse> updateItem(
            @RequestHeader("X-Customer-Id") Long customerId,
            @PathVariable Long itemId,
            @RequestParam int quantity) {

        return ResponseEntity.ok(
                cartService.updateItem(customerId, itemId, quantity)
        );
    }

    // ✅ REMOVE Item
    @DeleteMapping("/items/{itemId}")
    public ResponseEntity<CartResponse> removeItem(
            @RequestHeader("X-Customer-Id") Long customerId,
            @PathVariable Long itemId) {

        return ResponseEntity.ok(
                cartService.updateItem(customerId, itemId, 0)
        );
    }
}